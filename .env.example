# App
HTTP_ADDR=:8080
APP_MODE=all
SHUTDOWN_TIMEOUT_SECONDS=15

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5433/tickets?sslmode=disable
DB_MAX_RETRIES=20
DB_RETRY_BACKOFF_SECONDS=2

# RabbitMQ
AMQP_URL=amqp://guest:guest@localhost:5672/
AMQP_QUEUE=tickets.triage
AMQP_MESSAGE_MAX_RETRIES=3
AMQP_MESSAGE_RETRY_DELAY_MS=2000
AMQP_MAX_RETRIES=20
AMQP_RETRY_BACKOFF_SECONDS=2

# Worker
WORKER_SLEEP_MS=1200
